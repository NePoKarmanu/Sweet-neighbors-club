POSTGRES_DB=sweet_neighbors_club
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

APP_DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/sweet_neighbors_club
APP_REDIS_URL=redis://redis:6379/0
APP_CELERY_BROKER_URL=redis://redis:6379/0
APP_CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_RESULT_EXPIRES_SECONDS=3600
CELERY_LOG_LEVEL=WARNING

JWT_SECRET=change-me-in-env
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

SCRAPING_BEAT_ENABLED=true
SCRAPING_INTERVAL_MINUTES=10
CIAN_COOKIE=
CIAN_USER_AGENT=
SCRAPER_STALE_MISSES_THRESHOLD=3
NOTIFICATIONS_MATCHER_BATCH_SIZE=100
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_CLAIMS_SUBJECT=mailto:admin@example.com
